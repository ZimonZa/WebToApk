# Copy this file to .env and fill in your values. NEVER commit .env.
#
# GitHub Personal Access Token (fine-grained) scoped to your builds repo with:
#   Contents: Read and write   |   Actions: Read and write   |   Workflows: Read and write
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx

# The repo that holds the WebToApk template + workflows (where builds run).
GITHUB_OWNER=your-github-username
GITHUB_REPO=WebToApk

# Branch the workflows live on (usually main).
GITHUB_BRANCH=main

# Local port for the GUI.
PORT=3000
